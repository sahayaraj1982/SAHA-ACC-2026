<!DOCTYPE html>
<html lang="ta">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SAHAYARAJ-2026 | PRO LOGIN SYSTEM</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.25/jspdf.plugin.autotable.min.js"></script>
    <style>
        :root { --p-bg: #0c40bb; --n-col: #ffffff; --out: #54301d; --btm: #0b08d4; --c-let: #e32b2b; --c-num: #1e40af; }
        body { background-color: #475569; font-family: 'Arial Black', sans-serif; overflow-x: hidden; margin: 0; }
        * { font-weight: 950 !important; }

        /* Login Screen */
        #loginOverlay { position: fixed; inset: 0; background: #1a202c; z-index: 1000; display: flex; justify-content: center; align-items: center; }
        .login-box { background: #2d3748; padding: 40px; border-radius: 20px; border: 5px solid #facc15; text-align: center; width: 350px; }
        .login-box input { width: 100%; padding: 15px; margin: 10px 0; border-radius: 10px; border: none; font-size: 18px; color: black; }
        .login-box button { width: 100%; padding: 15px; background: #f63; color: white; border: none; border-radius: 10px; font-weight: bold; cursor: pointer; border-bottom: 5px solid #b32d00; }
        
        /* Main App */
        .main-app-box { border: 10px solid var(--out); margin: 10px auto; border-radius: 40px; background: #f1f5f9; overflow-x: hidden; transition: 0.3s; }
        .premium-header { background-color: var(--p-bg); padding: 25px; border-bottom: 10px solid var(--btm); position: relative; }
        .cat-card { background: #fff; border: 5px solid var(--out); border-radius: 20px; text-align: center; padding: 10px; position: relative; }
        .btn-style { border-bottom: 6px solid #000; color: #fff !important; cursor: pointer; transition: 0.1s; text-transform: uppercase; }
        .btn-style:active { transform: translateY(3px); border-bottom-width: 3px; }
        .cp-card { background: #fff; width: 98%; max-width: 1300px; border-radius: 40px; padding: 20px; border: 10px solid #000; max-height: 95vh; overflow-y: auto; }
        .action-bar { display: flex; width: 100%; background: #000; padding: 5px; gap: 5px; }
        .action-btn { flex: 1; padding: 12px 0; border: 3px solid #fff; color: #fff; font-size: 14px; text-align: center; cursor: pointer; border-radius: 10px; transition: 0.2s; display: flex; align-items: center; justify-content: center; }
        .action-btn.active { background: #ffeb3b; color: #000; border-color: #000; }
        .logout-btn { background: #ff4444; color: white; padding: 5px 15px; border-radius: 10px; border: 3px solid black; font-size: 12px; cursor: pointer; }
    </style>
</head>
<body onload="init()">

<div id="loginOverlay">
    <div class="login-box">
        <h2 class="text-yellow-400 text-2xl mb-4">SAHAYARAJ-2026</h2>
        <p class="text-white mb-4">ACCESS PROTECTED</p>
        <input type="text" id="user" placeholder="Username">
        <input type="password" id="pass" placeholder="Password">
        <button onclick="checkLogin()">LOGIN NOW ✅</button>
    </div>
</div>

<div id="appPage" class="hidden">
    <div id="mainContainer" class="main-app-box mx-auto">
        <div class="premium-header">
            <div class="flex items-center justify-between">
                <div class="flex items-center gap-4">
                    <button id="backBtn" onclick="location.reload()" class="bg-red-600 w-12 h-12 rounded-full border-4 border-black text-white text-2xl">⬅</button>
                    <div>
                        <h1 id="dispTitle" class="text-4xl italic uppercase" style="color: var(--n-col);">SAHAYARAJ-2026</h1>
                        <div id="liveDateTime" class="text-yellow-300 font-bold" style="font-size: 14px;"></div>
                        <p id="startDateDisplay" class="mb-1 text-yellow-300"></p>
                        <p id="expiryDisplay" class="mt-1 text-orange-400"></p>
                    </div>
                </div>
                <div class="flex items-center gap-6">
                    <div class="text-right text-white">
                        <button onclick="logout()" class="logout-btn mb-2">LOGOUT 🔓</button>
                        <p class="text-xs opacity-70">RECORDS: <span id="recCount" class="text-yellow-400">0</span></p>
                        <h2 id="mainTotal" class="text-4xl">₹0</h2>
                    </div>
                    <button onclick="openSettings()" class="text-5xl text-white">⚙️</button>
                </div>
            </div>
        </div>

        <div class="action-bar">
            <div class="action-btn" style="background:#facc15; color:#000" onclick="document.getElementById('bellStartDate').showPicker()">🔔 BELL <input type="date" id="bellStartDate" onchange="setStartingDate()" class="absolute opacity-0 pointer-events-none w-0"></div>
            <div id="viewCR" onclick="setViewMode('CR')" class="action-btn active">CREDIT (+)</div>
            <div id="viewDR" onclick="setViewMode('DR')" class="action-btn">DEBIT (-)</div>
            <div id="viewBOTH" onclick="setViewMode('BOTH')" class="action-btn">BOTH</div>
        </div>

        <div class="p-4">
            <div id="catGrid" class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-7 gap-3 mb-6"></div>
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                <div class="bg-white p-5 rounded-3xl border-4 border-black">
                    <h3 class="text-xl border-b-4 border-green-600 mb-4 italic uppercase">New Entry</h3>
                    <div class="grid grid-cols-2 gap-3">
                        <input type="date" id="eDate" class="border-2 border-black p-2 rounded">
                        <input type="tel" id="eMob" placeholder="Mobile" class="border-2 border-black p-2 rounded">
                        <select id="eCat" class="border-2 border-black p-2 rounded"></select>
                        <input type="text" id="eDesc" placeholder="Remark" class="border-2 border-black p-2 rounded">
                        <input type="number" id="eAmt" placeholder="Amount" class="border-2 border-black p-2 rounded">
                        <select id="eType" class="border-2 border-black p-2 rounded"><option value="CR">IN (+)</option><option value="DR">OUT (-)</option></select>
                    </div>
                    <button onclick="saveData()" class="w-full py-4 mt-5 rounded-xl text-xl btn-style bg-green-600">SAVE ✅</button>
                </div>
                <div class="bg-white p-5 rounded-3xl border-4 border-black">
                    <h3 class="text-xl border-b-4 border-blue-600 mb-4 italic uppercase">Search & Tools</h3>
                    <div class="grid grid-cols-2 md:grid-cols-4 gap-2 mb-4">
                        <input type="date" id="fDate" class="text-xs border-2 border-black p-1"><input type="date" id="tDate" class="text-xs border-2 border-black p-1">
                        <input type="tel" id="sMob" placeholder="Mobile" class="text-xs border-2 border-black p-1"><input type="text" id="sDesc" placeholder="Remark Search" class="text-xs border-2 border-black p-1">
                    </div>
                    <div id="filterCatList" class="flex flex-wrap gap-2 mb-4"></div>
                    <div class="grid grid-cols-4 gap-2">
                        <button id="pdfBtn" onclick="downloadPDF()" class="bg-orange-600 py-3 rounded-lg btn-style text-[9px]">PDF</button>
                        <button id="waBtn" onclick="sendWhatsApp()" class="bg-green-600 py-3 rounded-lg btn-style text-[9px]">W/APP</button>
                        <button id="impBtn" onclick="document.getElementById('impFile').click()" class="bg-blue-600 py-3 rounded-lg btn-style text-[9px]">IMPORT</button>
                        <button id="expBtn" onclick="exportData()" class="bg-purple-600 py-3 rounded-lg btn-style text-[9px]">EXPORT</button>
                    </div>
                    <button onclick="refresh()" class="w-full bg-slate-800 text-white py-3 mt-3 rounded-xl btn-style">SEARCH DATA 🔎</button>
                </div>
            </div>
            <div class="mt-6 bg-white border-4 border-black rounded-3xl overflow-hidden">
                <table class="w-full text-sm">
                    <thead class="bg-black text-white"><tr><th class="p-2">DATE</th><th class="p-2">MOBILE</th><th class="p-2">CAT</th><th class="p-2">REMARK</th><th class="p-2 text-right">AMOUNT</th><th class="p-2 text-center">ACTION</th></tr></thead>
                    <tbody id="resTable" class="text-center"></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script>
    const GOOGLE_SCRIPT_URL = "https://script.google.com/macros/s/AKfycbxWTEEmG3FbvRCHIkO1IgAaOXma3VZECF5vMxcU85Ye0GzBmjdLL8_Jg5aBDuRJ6Hr3/exec";

    function checkLogin() {
        const u = document.getElementById("user").value;
        const p = document.getElementById("pass").value;
        
        // Fetch logic based on your Google Script
        fetch(`${GOOGLE_SCRIPT_URL}?action=login&username=${u}&password=${p}`)
        .then(res => res.text())
        .then(data => {
            if(data.trim() === "success") {
                sessionStorage.setItem("isAuth", "true");
                document.getElementById("loginOverlay").style.display = "none";
                document.getElementById("appPage").classList.remove("hidden");
                init();
            } else {
                alert("தவறான விவரங்கள்!");
            }
        }).catch(err => alert("Error connecting to server"));
    }

    function logout() { sessionStorage.clear(); location.reload(); }

    // YOUR ORIGINAL APP LOGIC
    let cfg = JSON.parse(localStorage.getItem('saha_v66_cfg')) || {
        "title":"SAHAYARAJ-2026", "headCol":"#0c40bb", "nameCol":"#ffffff", "outCol":"#54301d", "btmCol":"#0b08d4", "catLetCol":"#e32b2b", "catNumCol":"#1e40af",
        "scrW":95, "fsDT":22, "fsCatL":14, "fsCatN":28, "fsEnt":14,
        "swBack":true, "swDate":true, "swClock":true, "swPen":true, "swTrDel":true, "swAllDel":true, "swPdf":true, "swWa":true, "swImp":true, "swExp":true,
        "adminPin":"1020", "loginPin":"1002", "expiryDate":"2027-01-20", "startingDate":"", "cats":[]
    };
    let db = JSON.parse(localStorage.getItem('saha_v66_db')) || [];
    let activeFilters = [];
    let currentViewMode = "CR";

    function init() {
        if(sessionStorage.getItem("isAuth") !== "true") return;
        document.getElementById("loginOverlay").style.display = "none";
        document.getElementById("appPage").classList.remove("hidden");
        
        document.documentElement.style.setProperty('--p-bg', cfg.headCol);
        document.getElementById('mainContainer').style.width = cfg.scrW + "%";
        document.getElementById('dispTitle').innerText = cfg.title;
        startClock(); renderUI(); refresh();
    }

    function startClock() { setInterval(() => { const now = new Date(); document.getElementById('liveDateTime').innerHTML = `${now.toLocaleDateString('en-GB')} | ${now.toLocaleTimeString('en-GB')}`; }, 1000); }

    function renderUI() {
        const grid = document.getElementById('catGrid'), eSel = document.getElementById('eCat'), fList = document.getElementById('filterCatList');
        grid.innerHTML = ""; eSel.innerHTML = ""; fList.innerHTML = `<button onclick="toggleFilter('ALL')" class="bg-blue-900 text-white px-3 py-1 rounded-lg">ALL</button>`;
        cfg.cats.forEach((c) => {
            grid.innerHTML += `<div class="cat-card"><p style="color:var(--c-let)">${c}</p><h3>₹<span id="sum_${c}">0</span></h3></div>`;
            eSel.innerHTML += `<option value="${c}">${c}</option>`;
            fList.innerHTML += `<button onclick="toggleFilter('${c}')" id="btn_${c}" class="bg-blue-900 text-white px-3 py-1 rounded-lg">${c}</button>`;
        });
    }

    function refresh() {
        let html = "", grand = 0;
        let tempSums = {}; cfg.cats.forEach(c => tempSums[c] = 0);
        let filtered = db.filter(t => (currentViewMode === "BOTH" || t.type === currentViewMode));

        filtered.forEach(t => {
            let amt = parseFloat(t.amt) || 0;
            let v = (t.type === "CR") ? amt : -amt;
            if(tempSums.hasOwnProperty(t.cat)) tempSums[t.cat] += v;
            grand += v;
            html += `<tr class="border-b"><td class="p-2">${t.date}</td><td class="p-2">${t.mob}</td><td class="p-2">${t.cat}</td><td class="p-2">${t.desc}</td><td class="p-2 text-right">₹${amt}</td><td class="p-2">✖</td></tr>`;
        });
        document.getElementById('resTable').innerHTML = html;
        document.getElementById('mainTotal').innerText = "₹" + grand.toLocaleString();
        cfg.cats.forEach(c => { if(document.getElementById('sum_'+c)) document.getElementById('sum_'+c).innerText = tempSums[c].toLocaleString(); });
    }

    function saveData() {
        let entry = { id: Date.now(), date: document.getElementById('eDate').value, mob: document.getElementById('eMob').value, cat: document.getElementById('eCat').value, desc: document.getElementById('eDesc').value, amt: document.getElementById('eAmt').value, type: document.getElementById('eType').value };
        db.push(entry); localStorage.setItem('saha_v66_db', JSON.stringify(db)); refresh();
    }
</script>
</body>
</html>
