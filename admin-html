<!DOCTYPE html>
<html lang="ta">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SAHAYARAJ - ADMIN PANEL</title>
    <style>
        body { background: #0f172a; color: white; font-family: sans-serif; padding: 20px; }
        .container { max-width: 900px; margin: auto; background: #1e293b; padding: 30px; border-radius: 20px; border: 5px solid #b8860b; box-shadow: 0 0 20px rgba(0,0,0,0.5); }
        h1 { text-align: center; color: #fbbf24; text-transform: uppercase; }
        .btn-box { text-align: center; margin-bottom: 20px; }
        .btn-sheet { background: #22c55e; color: white; padding: 12px 25px; border-radius: 10px; text-decoration: none; font-weight: bold; border-bottom: 4px solid #166534; display: inline-block; }
        .btn-sheet:active { transform: translateY(2px); border-bottom-width: 2px; }
        table { width: 100%; border-collapse: collapse; margin-top: 20px; background: #0f172a; }
        th, td { border: 1px solid #334155; padding: 15px; text-align: center; }
        th { background: #334155; color: #fbbf24; }
        .status-active { color: #22c55e; font-weight: bold; }
        .status-blocked { color: #ef4444; font-weight: bold; }
        .loading { text-align: center; color: #fbbf24; }
    </style>
</head>
<body>

<div class="container">
    <h1>ADMIN CONTROL PANEL ⚙️</h1>
    
    <div class="btn-box">
        <a href="https://docs.google.com/spreadsheets/d/1X5vM_jV7S_Y1YI_W4A-v6XlI9R0R1A_XyX_X_X_X" target="_blank" class="btn-sheet">
            EDIT USERS IN GOOGLE SHEET 📝
        </a>
    </div>

    <div id="loader" class="loading">தகவல்கள் சேகரிக்கப்படுகிறது...</div>
    
    <table id="userTable" style="display:none;">
        <thead>
            <tr>
                <th>USERNAME</th>
                <th>PASSWORD</th>
                <th>CURRENT STATUS</th>
            </tr>
        </thead>
        <tbody id="tableBody">
            </tbody>
    </table>
</div>

<script>
    async function loadUsers() {
        const sheetURL = "https://script.google.com/macros/s/AKfycbx8KE2IhOkNo-J5D2j-jgGBqeBQHfad27fYNAPaDFpNbSl-cL8n4Jjv5D9iRTDJkNDL/exec";
        try {
            const response = await fetch(sheetURL);
            const data = await response.json();
            const tbody = document.getElementById('tableBody');
            
            tbody.innerHTML = "";
            // முதல் வரியைத் தவிர்த்து (Header) மற்றவற்றை எடுக்கிறது
            for(let i = 1; i < data.length; i++) {
                let status = data[i][2];
                let statusClass = status === "Active" ? "status-active" : "status-blocked";
                
                tbody.innerHTML += `
                    <tr>
                        <td style="font-weight:bold;">${data[i][0]}</td>
                        <td>****</td>
                        <td class="${statusClass}">${status}</td>
                    </tr>
                `;
            }
            document.getElementById('loader').style.display = 'none';
            document.getElementById('userTable').style.display = 'table';
        } catch (e) {
            document.getElementById('loader').innerText = "பிழை: தகவல்களை எடுக்க முடியவில்லை!";
        }
    }
    loadUsers();
</script>

</body>
</html>
